# ─── Color palette ───────────────────────────────────────────────────────────
BG    = '#0d0d10'
CARD  = '#1c1c20'
INSET = '#111113'
BLUE  = '#3b82f6'
GREEN = '#22c55e'
AMBER = '#f59e0b'
RED   = '#ef4444'
TEAL  = '#14b8a6'
GRAY  = '#6b7280'
TEXT  = '#e5e7eb'
SUB   = '#9ca3af'
DIM   = '#4b5563'

# ─── Paths ────────────────────────────────────────────────────────────────────
DB_PATH     = Path.home() / '.local/share/disk-monitor/stats.db'
CLEANER     = str(Path.home() / '.local/bin/disk-cleaner')
CONFIG_PATH = Path.home() / '.config/disk-monitor/config.sh'


# ─── Database helpers ─────────────────────────────────────────────────────────
def get_conn():
    if not DB_PATH.exists():
        return None
    try:
        conn = sqlite3.connect(str(DB_PATH))
        conn.row_factory = sqlite3.Row
        return conn
    except Exception:
        return None


def db_fetch(sql, params=()):
    conn = get_conn()
    if conn is None:
        return []
    try:
        cur = conn.execute(sql, params)
        rows = cur.fetchall()
        conn.close()
        return rows
    except Exception:
        try:
            conn.close()
        except Exception:
            pass
        return []


def db_one(sql, params=()):
    rows = db_fetch(sql, params)
    return rows[0] if rows else None


# ─── StatCard ─────────────────────────────────────────────────────────────────
class StatCard(QFrame):
    def __init__(self, label, value='—', sub='', color=TEAL, parent=None):
        super().__init__(parent)
        self._color = color
        self.setObjectName('statCard')
        self.setStyleSheet(f'''
            #statCard {{
                background:{CARD};
                border:1px solid rgba(255,255,255,0.08);
                border-radius:10px;
            }}
        ''')
        self.setSizePolicy(QSizePolicy.Expanding, QSizePolicy.Fixed)
        self.setMinimumHeight(100)

        layout = QVBoxLayout(self)
        layout.setContentsMargins(16, 14, 16, 14)
        layout.setSpacing(4)

        # Top row: label + dot
        top = QHBoxLayout()
        lbl = QLabel(label.upper())
        lbl.setStyleSheet(f'color:{DIM};font-size:10px;font-weight:600;letter-spacing:0.06em;')
        dot = QLabel('●')
        dot.setStyleSheet(f'color:{color};font-size:10px;')
        top.addWidget(lbl)
        top.addStretch()
        top.addWidget(dot)
        layout.addLayout(top)

        # Value
        self._val_lbl = QLabel(str(value))
        self._val_lbl.setStyleSheet(f'color:{TEXT};font-size:22px;font-weight:700;')
        layout.addWidget(self._val_lbl)

        # Sub
        if sub:
            sub_lbl = QLabel(sub)
            sub_lbl.setStyleSheet(f'color:{DIM};font-size:11px;')
            layout.addWidget(sub_lbl)
        self._sub_lbl = QLabel(sub)
        self._sub_lbl.setStyleSheet(f'color:{DIM};font-size:11px;')
        if not sub:
            self._sub_lbl.hide()
        elif sub:
            layout.addWidget(self._sub_lbl)

    def set_value(self, value, sub=None):
        self._val_lbl.setText(str(value))
        if sub is not None:
            self._sub_lbl.setText(sub)
            self._sub_lbl.show()


# ─── UsageBar ─────────────────────────────────────────────────────────────────
class UsageBar(QWidget):
    def __init__(self, partition, parent=None):
        super().__init__(parent)
        self._partition = partition
        layout = QHBoxLayout(self)
        layout.setContentsMargins(0, 0, 0, 0)
        layout.setSpacing(8)

        self._lbl = QLabel(partition)
        self._lbl.setFixedWidth(50)
        self._lbl.setStyleSheet(f'color:{SUB};font-family:monospace;font-size:11px;')
        layout.addWidget(self._lbl)

        self._bar = QProgressBar()
        self._bar.setTextVisible(False)
        self._bar.setFixedHeight(10)
        self._bar.setRange(0, 100)
        layout.addWidget(self._bar, 1)

        self._text = QLabel('— / —')
        self._text.setStyleSheet(f'color:{SUB};font-size:11px;font-family:monospace;')
        self._text.setFixedWidth(130)
        layout.addWidget(self._text)

        self.refresh()

    def refresh(self):
        try:
            usage = shutil.disk_usage(self._partition)
            pct = int(usage.used / usage.total * 100)
            used_g = usage.used / (1024 ** 3)
            total_g = usage.total / (1024 ** 3)
            color = GREEN if pct < 70 else BLUE if pct < 85 else AMBER if pct < 92 else RED
            self._bar.setValue(pct)
            self._bar.setStyleSheet(f'''
                QProgressBar {{
                    background:{INSET};
                    border:none;
                    border-radius:5px;
                }}
                QProgressBar::chunk {{
                    background:{color};
                    border-radius:5px;
                }}
            ''')
            self._text.setText(f'{used_g:.1f}G / {total_g:.1f}G')
        except Exception:
            self._bar.setValue(0)
            self._text.setText('N/A')


# ─── Chart (FigureCanvas wrapper) ─────────────────────────────────────────────
class Chart(FigureCanvas):
    def __init__(self, figsize=(6, 3), parent=None):
        self._fig = Figure(figsize=figsize, facecolor=INSET)
        super().__init__(self._fig)
        self.setParent(parent)
        self.setSizePolicy(QSizePolicy.Expanding, QSizePolicy.Expanding)
        self._ax = self._fig.add_subplot(111)
        self._style_ax()

    def _style_ax(self):
        ax = self._ax
        ax.set_facecolor(INSET)
        ax.tick_params(colors=DIM, labelsize=9)
        for spine in ax.spines.values():
            spine.set_edgecolor('#1a1a1f')
        ax.grid(color='#1f2937', linestyle='--', alpha=0.5)

    def clear(self):
        self._fig.clear()
        self._ax = self._fig.add_subplot(111)
        self._style_ax()

    def no_data(self, msg='No data — run disk-cleaner first'):
        self.clear()
        self._ax.text(
            0.5, 0.5, msg,
            transform=self._ax.transAxes,
            ha='center', va='center',
            color=DIM, fontsize=11
        )
        self._ax.set_xticks([])
        self._ax.set_yticks([])
        self.draw()


# ─── Tab 1: Dashboard ─────────────────────────────────────────────────────────
class DashboardTab(QWidget):
    def __init__(self, parent=None):
        super().__init__(parent)
        layout = QVBoxLayout(self)
        layout.setContentsMargins(16, 16, 16, 16)
        layout.setSpacing(12)

        # Stat cards row
        cards_row = QHBoxLayout()
        cards_row.setSpacing(10)
        self._card_freed  = StatCard('Total Freed',   '—',   'all time',  TEAL)
        self._card_runs   = StatCard('Cleanups Run',  '0',   '',          BLUE)
        self._card_last   = StatCard('Last Cleanup',  '—',   '',          GREEN)
        self._card_avg    = StatCard('Avg per Run',   '—',   '',          AMBER)
        for c in (self._card_freed, self._card_runs, self._card_last, self._card_avg):
            cards_row.addWidget(c)
        layout.addLayout(cards_row)

        # Charts row
        charts_row = QHBoxLayout()
        charts_row.setSpacing(10)

        # Donut chart frame
        donut_frame = QFrame()
        donut_frame.setStyleSheet(f'background:{CARD};border:1px solid rgba(255,255,255,0.08);border-radius:10px;')
        donut_layout = QVBoxLayout(donut_frame)
        donut_layout.setContentsMargins(12, 12, 12, 12)
        ttl = QLabel('Freed by Cache Type (all time)')
        ttl.setStyleSheet(f'color:{SUB};font-size:11px;font-weight:600;')
        donut_layout.addWidget(ttl)
        self._donut = Chart(figsize=(5, 3.5))
        donut_layout.addWidget(self._donut)
        charts_row.addWidget(donut_frame, 3)

        # Recent cleanups table frame
        recent_frame = QFrame()
        recent_frame.setStyleSheet(f'background:{CARD};border:1px solid rgba(255,255,255,0.08);border-radius:10px;')
        recent_layout = QVBoxLayout(recent_frame)
        recent_layout.setContentsMargins(12, 12, 12, 12)
        ttl2 = QLabel('Recent Cleanups')
        ttl2.setStyleSheet(f'color:{SUB};font-size:11px;font-weight:600;')
        recent_layout.addWidget(ttl2)
        self._recent_tbl = QTableWidget(0, 3)
        self._recent_tbl.setHorizontalHeaderLabels(['Time', 'Trigger', 'Freed'])
        self._recent_tbl.horizontalHeader().setSectionResizeMode(QHeaderView.Stretch)
        self._recent_tbl.setEditTriggers(QTableWidget.NoEditTriggers)
        self._recent_tbl.setSelectionMode(QTableWidget.NoSelection)
        self._recent_tbl.verticalHeader().setVisible(False)
        recent_layout.addWidget(self._recent_tbl)
        charts_row.addWidget(recent_frame, 2)

        layout.addLayout(charts_row)

    def refresh(self):
        # Stats
        total_row = db_one('SELECT SUM(total_freed) as tot, COUNT(*) as cnt FROM cleanups')
        if total_row and total_row['cnt']:
            tot_mb = (total_row['tot'] or 0) / 1024
            cnt = total_row['cnt']
            avg_mb = tot_mb / cnt if cnt else 0
            self._card_freed.set_value(f'{tot_mb:.1f} MB')
            self._card_runs.set_value(str(cnt))
            self._card_avg.set_value(f'{avg_mb:.1f} MB')
        else:
            self._card_freed.set_value('0 MB')
            self._card_runs.set_value('0')
            self._card_avg.set_value('—')

        last_row = db_one('SELECT ts FROM cleanups ORDER BY ts DESC LIMIT 1')
        if last_row:
            try:
                dt = datetime.fromisoformat(last_row['ts'])
                self._card_last.set_value(dt.strftime('%m/%d %H:%M'))
            except Exception:
                self._card_last.set_value(str(last_row['ts'])[:16])
        else:
            self._card_last.set_value('Never')

        # Donut chart
        rows = db_fetch(
            'SELECT name, SUM(freed_kb) as total FROM actions WHERE status="ok" GROUP BY name ORDER BY total DESC'
        )
        self._donut.clear()
        if rows:
            names = [r['name'] for r in rows]
            values = [r['total'] for r in rows]
            colors = [TEAL, BLUE, GREEN, AMBER, RED, GRAY, SUB, DIM,
                      '#a78bfa', '#f472b6', '#34d399', '#60a5fa'][:len(names)]
            wedges, _ = self._donut._ax.pie(
                values,
                labels=None,
                colors=colors,
                startangle=90,
                wedgeprops=dict(width=0.5, edgecolor=INSET, linewidth=2),
            )
            # Legend
            self._donut._ax.legend(
                wedges,
                [f'{n} ({v/1024:.1f}M)' for n, v in zip(names, values)],
                loc='center left',
                bbox_to_anchor=(0.85, 0.5),
                fontsize=7,
                framealpha=0,
                labelcolor=SUB,
            )
            self._donut._fig.tight_layout()
            self._donut.draw()
        else:
            self._donut.no_data()

        # Recent cleanups table
        recent = db_fetch('SELECT ts, trigger, total_freed FROM cleanups ORDER BY ts DESC LIMIT 8')
        self._recent_tbl.setRowCount(len(recent))
        for i, r in enumerate(recent):
            try:
                dt = datetime.fromisoformat(r['ts'])
                ts_str = dt.strftime('%m/%d %H:%M')
            except Exception:
                ts_str = str(r['ts'])[:16]
            freed_mb = (r['total_freed'] or 0) / 1024
            self._recent_tbl.setItem(i, 0, QTableWidgetItem(ts_str))
            self._recent_tbl.setItem(i, 1, QTableWidgetItem(str(r['trigger'] or '')))
            self._recent_tbl.setItem(i, 2, QTableWidgetItem(f'{freed_mb:.1f} MB'))
            for col in range(3):
                item = self._recent_tbl.item(i, col)
                if item:
                    item.setForeground(QColor(TEXT))


# ─── Tab 2: History ───────────────────────────────────────────────────────────
class HistoryTab(QWidget):
    def __init__(self, parent=None):
        super().__init__(parent)
        layout = QVBoxLayout(self)
        layout.setContentsMargins(16, 16, 16, 16)

        splitter = QSplitter(Qt.Vertical)

        # Top: cleanups table
        top_widget = QWidget()
        top_layout = QVBoxLayout(top_widget)
        top_layout.setContentsMargins(0, 0, 0, 0)
        top_lbl = QLabel('All Cleanups')
        top_lbl.setStyleSheet(f'color:{SUB};font-size:11px;font-weight:600;margin-bottom:4px;')
        top_layout.addWidget(top_lbl)
        self._cleanups_tbl = QTableWidget(0, 4)
        self._cleanups_tbl.setHorizontalHeaderLabels(['Timestamp', 'Trigger', 'Freed', '/home Δ'])
        self._cleanups_tbl.horizontalHeader().setSectionResizeMode(QHeaderView.Stretch)
        self._cleanups_tbl.setEditTriggers(QTableWidget.NoEditTriggers)
        self._cleanups_tbl.setSelectionMode(QTableWidget.SingleSelection)
        self._cleanups_tbl.setSelectionBehavior(QTableWidget.SelectRows)
        self._cleanups_tbl.verticalHeader().setVisible(False)
        self._cleanups_tbl.selectionModel().selectionChanged.connect(self._on_select)
        top_layout.addWidget(self._cleanups_tbl)
        splitter.addWidget(top_widget)

        # Bottom: per-cleaner breakdown
        bottom_widget = QWidget()
        bottom_layout = QVBoxLayout(bottom_widget)
        bottom_layout.setContentsMargins(0, 0, 0, 0)
        bottom_lbl = QLabel('Cleaner Breakdown')
        bottom_lbl.setStyleSheet(f'color:{SUB};font-size:11px;font-weight:600;margin-bottom:4px;')
        bottom_layout.addWidget(bottom_lbl)
        self._detail_tbl = QTableWidget(0, 3)
        self._detail_tbl.setHorizontalHeaderLabels(['Cleaner', 'Freed', 'Status'])
        self._detail_tbl.horizontalHeader().setSectionResizeMode(QHeaderView.Stretch)
        self._detail_tbl.setEditTriggers(QTableWidget.NoEditTriggers)
        self._detail_tbl.setSelectionMode(QTableWidget.NoSelection)
        self._detail_tbl.verticalHeader().setVisible(False)
        self._placeholder = QLabel('Select a cleanup above to see details')
        self._placeholder.setStyleSheet(f'color:{DIM};font-size:12px;')
        self._placeholder.setAlignment(Qt.AlignCenter)
        bottom_layout.addWidget(self._placeholder)
        bottom_layout.addWidget(self._detail_tbl)
        self._detail_tbl.hide()
        splitter.addWidget(bottom_widget)

        splitter.setSizes([300, 200])
        layout.addWidget(splitter)
        self._cleanup_ids = []

    def refresh(self):
        rows = db_fetch(
            'SELECT id, ts, trigger, total_freed, home_before, home_after FROM cleanups ORDER BY ts DESC'
        )
        self._cleanup_ids = []
        self._cleanups_tbl.setRowCount(len(rows))
        for i, r in enumerate(rows):
            self._cleanup_ids.append(r['id'])
            try:
                dt = datetime.fromisoformat(r['ts'])
                ts_str = dt.strftime('%Y-%m-%d %H:%M')
            except Exception:
                ts_str = str(r['ts'])[:16]
            freed_mb = (r['total_freed'] or 0) / 1024
            home_before = r['home_before'] or 0
            home_after  = r['home_after']  or 0
            delta = home_before - home_after
            delta_str = f'-{delta/1024:.1f} MB' if delta else '—'
            self._cleanups_tbl.setItem(i, 0, QTableWidgetItem(ts_str))
            self._cleanups_tbl.setItem(i, 1, QTableWidgetItem(str(r['trigger'] or '')))
            self._cleanups_tbl.setItem(i, 2, QTableWidgetItem(f'{freed_mb:.1f} MB'))
            self._cleanups_tbl.setItem(i, 3, QTableWidgetItem(delta_str))
            for col in range(4):
                item = self._cleanups_tbl.item(i, col)
                if item:
                    item.setForeground(QColor(TEXT))

    def _on_select(self):
        rows = self._cleanups_tbl.selectedItems()
        if not rows:
            self._detail_tbl.hide()
            self._placeholder.show()
            return
        row_idx = self._cleanups_tbl.currentRow()
        if row_idx < 0 or row_idx >= len(self._cleanup_ids):
            return
        cleanup_id = self._cleanup_ids[row_idx]
        actions = db_fetch(
            'SELECT name, freed_kb, status FROM actions WHERE cleanup_id=? ORDER BY freed_kb DESC',
            (cleanup_id,)
        )
        self._detail_tbl.setRowCount(len(actions))
        status_colors = {'ok': GREEN, 'error': RED, 'skipped': GRAY}
        for i, a in enumerate(actions):
            freed_mb = (a['freed_kb'] or 0) / 1024
            status_str = str(a['status'] or '')
            self._detail_tbl.setItem(i, 0, QTableWidgetItem(str(a['name'] or '')))
            self._detail_tbl.setItem(i, 1, QTableWidgetItem(f'{freed_mb:.1f} MB'))
            status_item = QTableWidgetItem(status_str)
            status_item.setForeground(QColor(status_colors.get(status_str, SUB)))
            self._detail_tbl.setItem(i, 2, status_item)
            for col in (0, 1):
                item = self._detail_tbl.item(i, col)
                if item:
                    item.setForeground(QColor(TEXT))
        self._placeholder.hide()
        self._detail_tbl.show()


# ─── Tab 3: Analytics ─────────────────────────────────────────────────────────
class AnalyticsTab(QWidget):
    def __init__(self, parent=None):
        super().__init__(parent)
        layout = QVBoxLayout(self)
        layout.setContentsMargins(16, 16, 16, 16)
        layout.setSpacing(12)

        # /home usage line chart
        frame1 = QFrame()
        frame1.setStyleSheet(f'background:{CARD};border:1px solid rgba(255,255,255,0.08);border-radius:10px;')
        fl1 = QVBoxLayout(frame1)
        fl1.setContentsMargins(12, 12, 12, 12)
        lbl1 = QLabel('/home Usage % — Last 30 Days')
        lbl1.setStyleSheet(f'color:{SUB};font-size:11px;font-weight:600;')
        fl1.addWidget(lbl1)
        self._usage_chart = Chart(figsize=(8, 2.8))
        fl1.addWidget(self._usage_chart)
        layout.addWidget(frame1)

        # Freed per cleanup bar chart
        frame2 = QFrame()
        frame2.setStyleSheet(f'background:{CARD};border:1px solid rgba(255,255,255,0.08);border-radius:10px;')
        fl2 = QVBoxLayout(frame2)
        fl2.setContentsMargins(12, 12, 12, 12)
        lbl2 = QLabel('Freed per Cleanup (MB) — Last 20 Runs')
        lbl2.setStyleSheet(f'color:{SUB};font-size:11px;font-weight:600;')
        fl2.addWidget(lbl2)
        self._freed_chart = Chart(figsize=(8, 2.8))
        fl2.addWidget(self._freed_chart)
        layout.addWidget(frame2)

    def refresh(self):
        self._draw_usage()
        self._draw_freed()

    def _draw_usage(self):
        cutoff = (datetime.now() - timedelta(days=30)).isoformat()
        rows = db_fetch(
            '''SELECT date(ts) as day, AVG(used_kb * 100.0 / total_kb) as pct
               FROM snapshots
               WHERE partition="/home" AND ts >= ?
               GROUP BY date(ts)
               ORDER BY day''',
            (cutoff,)
        )
        self._usage_chart.clear()
        ax = self._usage_chart._ax
        if rows:
            days = [r['day'] for r in rows]
            pcts = [r['pct'] or 0 for r in rows]
            ax.plot(range(len(days)), pcts, color=BLUE, linewidth=2, marker='o', markersize=4)
            ax.fill_between(range(len(days)), pcts, alpha=0.15, color=BLUE)
            step = max(1, len(days) // 6)
            ax.set_xticks(range(0, len(days), step))
            ax.set_xticklabels([days[i][5:] for i in range(0, len(days), step)],
                               color=DIM, fontsize=8, rotation=30)
            ax.set_ylabel('%', color=DIM, fontsize=9)
            ax.set_ylim(0, 100)
            ax.yaxis.label.set_color(DIM)
            self._usage_chart._fig.tight_layout()
            self._usage_chart.draw()
        else:
            self._usage_chart.no_data('No /home snapshots yet')

    def _draw_freed(self):
        rows = db_fetch(
            'SELECT ts, trigger, total_freed FROM cleanups ORDER BY ts DESC LIMIT 20'
        )
        self._freed_chart.clear()
        ax = self._freed_chart._ax
        if rows:
            rows = list(reversed(rows))
            values_mb = [(r['total_freed'] or 0) / 1024 for r in rows]
            trigger_colors = {
                'auto': BLUE, 'manual': GREEN, 'critical': RED,
                'scheduled': AMBER, 'cron': TEAL,
            }
            bar_colors = [trigger_colors.get(str(r['trigger'] or '').lower(), GRAY)
                          for r in rows]
            x = range(len(rows))
            ax.bar(x, values_mb, color=bar_colors, width=0.7)
            labels = []
            for r in rows:
                try:
                    dt = datetime.fromisoformat(r['ts'])
                    labels.append(dt.strftime('%m/%d'))
                except Exception:
                    labels.append(str(r['ts'])[:5])
            step = max(1, len(rows) // 8)
            ax.set_xticks(list(range(0, len(rows), step)))
            ax.set_xticklabels([labels[i] for i in range(0, len(rows), step)],
                               color=DIM, fontsize=8, rotation=30)
            ax.set_ylabel('MB', color=DIM, fontsize=9)
            self._freed_chart._fig.tight_layout()
            self._freed_chart.draw()
        else:
            self._freed_chart.no_data('No cleanups yet')


# ─── Tab 4: Cleanup ───────────────────────────────────────────────────────────
class CleanupTab(QWidget):
    cleanup_done = pyqtSignal()

    def __init__(self, parent=None):
        super().__init__(parent)
        layout = QVBoxLayout(self)
        layout.setContentsMargins(16, 16, 16, 16)
        layout.setSpacing(12)

        # Usage label
        self._usage_lbl = QLabel()
        self._usage_lbl.setStyleSheet(f'color:{TEXT};font-size:14px;')
        layout.addWidget(self._usage_lbl)

        # Run button
        self._run_btn = QPushButton('Run Cleanup Now')
        self._run_btn.setFixedHeight(44)
        self._run_btn.clicked.connect(self._run_cleanup)
        layout.addWidget(self._run_btn)

        # Output area
        out_lbl = QLabel('Output')
        out_lbl.setStyleSheet(f'color:{SUB};font-size:11px;font-weight:600;')
        layout.addWidget(out_lbl)
        self._output = QTextEdit()
        self._output.setReadOnly(True)
        self._output.setFont(QFont('monospace', 10))
        self._output.setSizePolicy(QSizePolicy.Expanding, QSizePolicy.Expanding)
        layout.addWidget(self._output)

        # Status
        self._status_lbl = QLabel('Idle')
        self._status_lbl.setStyleSheet(f'color:{GRAY};font-size:12px;')
        layout.addWidget(self._status_lbl)

        self._process = None
        self.refresh()

    def refresh(self):
        try:
            usage = shutil.disk_usage('/home')
            pct = int(usage.used / usage.total * 100)
            used_g = usage.used / (1024 ** 3)
            total_g = usage.total / (1024 ** 3)
            color = GREEN if pct < 70 else BLUE if pct < 85 else AMBER if pct < 92 else RED
            self._usage_lbl.setText(
                f'<span style="color:{color};font-size:24px;font-weight:700;">{pct}%</span>'
                f'<span style="color:{DIM};font-size:13px;"> used on /home ({used_g:.1f}G / {total_g:.1f}G)</span>'
            )
        except Exception:
            self._usage_lbl.setText('<span style="color:#6b7280;">Usage unavailable</span>')

    def _run_cleanup(self):
        if not os.path.exists(CLEANER):
            self._output.append(f'<span style="color:{RED};">disk-cleaner not found at {CLEANER}</span>')
            return
        self._run_btn.setEnabled(False)
        self._output.clear()
        self._status_lbl.setText('Running…')
        self._status_lbl.setStyleSheet(f'color:{AMBER};font-size:12px;')

        self._process = QProcess(self)
        self._process.setProcessChannelMode(QProcess.MergedChannels)
        self._process.readyReadStandardOutput.connect(self._on_output)
        self._process.finished.connect(self._on_done)
        self._process.start(CLEANER, [])

    def _on_output(self):
        if self._process:
            data = bytes(self._process.readAllStandardOutput()).decode('utf-8', errors='replace')
            self._output.moveCursor(self._output.textCursor().End)
            self._output.insertPlainText(data)

    def _on_done(self, exit_code, exit_status):
        self._run_btn.setEnabled(True)
        if exit_code == 0:
            self._status_lbl.setText('Done')
            self._status_lbl.setStyleSheet(f'color:{GREEN};font-size:12px;')
        else:
            self._status_lbl.setText(f'Exited with code {exit_code}')
            self._status_lbl.setStyleSheet(f'color:{RED};font-size:12px;')
        self.refresh()
        self.cleanup_done.emit()


# ─── Tab 5: Settings ─────────────────────────────────────────────────────────
class SettingsTab(QWidget):
    def __init__(self, parent=None):
        super().__init__(parent)
        layout = QVBoxLayout(self)
        layout.setContentsMargins(16, 16, 16, 16)
        layout.setSpacing(16)

        grp = QGroupBox('Thresholds & Intervals')
        grp.setStyleSheet(f'''
            QGroupBox {{
                color:{SUB};
                font-size:11px;
                font-weight:600;
                border:1px solid rgba(255,255,255,0.08);
                border-radius:8px;
                margin-top:8px;
            }}
            QGroupBox::title {{
                subcontrol-origin:margin;
                left:10px;
                padding:0 4px;
            }}
        ''')
        grp_layout = QVBoxLayout(grp)
        grp_layout.setSpacing(10)

        def make_row(label, key, lo=0, hi=100, suffix=''):
            row = QHBoxLayout()
            lbl = QLabel(f'{label}:')
            lbl.setStyleSheet(f'color:{TEXT};font-size:12px;')
            lbl.setFixedWidth(220)
            spin = QSpinBox()
            spin.setRange(lo, hi)
            spin.setSuffix(f' {suffix}' if suffix else '')
            spin.setFixedWidth(110)
            row.addWidget(lbl)
            row.addWidget(spin)
            row.addStretch()
            grp_layout.addLayout(row)
            return spin

        self._warn     = make_row('Warn Threshold',       'WARN_THRESHOLD',     0, 100, '%')
        self._clean    = make_row('Clean Threshold',      'CLEAN_THRESHOLD',    0, 100, '%')
        self._critical = make_row('Critical Threshold',   'CRITICAL_THRESHOLD', 0, 100, '%')
        self._cooldown = make_row('Cooldown',              'COOLDOWN',           0, 720, 'hours')
        self._check    = make_row('Check Interval',        'CHECK_INTERVAL',     1, 1440, 'min')
        self._snapshot = make_row('Snapshot Interval',    'SNAPSHOT_INTERVAL',  1, 1440, 'min')

        layout.addWidget(grp)

        btn_row = QHBoxLayout()
        save_btn = QPushButton('Save Settings')
        save_btn.setFixedHeight(38)
        save_btn.clicked.connect(self._save)
        restart_btn = QPushButton('Restart Monitor Service')
        restart_btn.setFixedHeight(38)
        restart_btn.clicked.connect(self._restart_service)
        btn_row.addWidget(save_btn)
        btn_row.addWidget(restart_btn)
        btn_row.addStretch()
        layout.addLayout(btn_row)

        self._msg = QLabel('')
        self._msg.setStyleSheet(f'color:{GREEN};font-size:12px;')
        layout.addWidget(self._msg)
        layout.addStretch()

        self._load_config()

    def _load_config(self):
        if not CONFIG_PATH.exists():
            return
        try:
            text = CONFIG_PATH.read_text()
            def get_val(key, default=0):
                m = re.search(rf'^{key}\s*=\s*(\d+)', text, re.MULTILINE)
                return int(m.group(1)) if m else default

            self._warn.setValue(get_val('WARN_THRESHOLD', 80))
            self._clean.setValue(get_val('CLEAN_THRESHOLD', 85))
            self._critical.setValue(get_val('CRITICAL_THRESHOLD', 92))
            # Config stores seconds; display as hours/minutes
            cooldown_sec = get_val('COOLDOWN', 14400)
            self._cooldown.setValue(cooldown_sec // 3600)
            check_sec = get_val('CHECK_INTERVAL', 300)
            self._check.setValue(check_sec // 60)
            snap_sec = get_val('SNAPSHOT_INTERVAL', 1800)
            self._snapshot.setValue(snap_sec // 60)
        except Exception as e:
            self._msg.setStyleSheet(f'color:{RED};font-size:12px;')
            self._msg.setText(f'Error loading config: {e}')

    def _save(self):
        if not CONFIG_PATH.exists():
            self._msg.setStyleSheet(f'color:{RED};font-size:12px;')
            self._msg.setText('Config file not found.')
            return
        try:
            text = CONFIG_PATH.read_text()

            def replace_val(key, value):
                return re.sub(
                    rf'^({key}\s*=\s*)\d+',
                    lambda m: m.group(1) + str(value),
                    text,
                    flags=re.MULTILINE,
                )

            text = replace_val('WARN_THRESHOLD',     self._warn.value())
            text = replace_val('CLEAN_THRESHOLD',    self._clean.value())
            text = replace_val('CRITICAL_THRESHOLD', self._critical.value())
            text = replace_val('COOLDOWN',           self._cooldown.value() * 3600)
            text = replace_val('CHECK_INTERVAL',     self._check.value() * 60)
            text = replace_val('SNAPSHOT_INTERVAL',  self._snapshot.value() * 60)

            CONFIG_PATH.write_text(text)
            self._msg.setStyleSheet(f'color:{GREEN};font-size:12px;')
            self._msg.setText('Settings saved.')
        except Exception as e:
            self._msg.setStyleSheet(f'color:{RED};font-size:12px;')
            self._msg.setText(f'Error saving: {e}')

    def _restart_service(self):
        proc = QProcess(self)
        proc.start('systemctl', ['--user', 'restart', 'disk-monitor.service'])
        proc.waitForFinished(5000)
        exit_code = proc.exitCode()
        if exit_code == 0:
            self._msg.setStyleSheet(f'color:{GREEN};font-size:12px;')
            self._msg.setText('Service restarted.')
        else:
            self._msg.setStyleSheet(f'color:{RED};font-size:12px;')
            self._msg.setText(f'Restart failed (exit {exit_code}).')


# ─── Main Window ──────────────────────────────────────────────────────────────
class MainWindow(QMainWindow):
    def __init__(self):
        super().__init__()
        self.setWindowTitle('Disk Monitor')
        self.resize(1100, 760)
        self._build_ui()
        self._apply_qss()
        self._refresh_all()

        self._timer = QTimer(self)
        self._timer.timeout.connect(self._refresh_all)
        self._timer.start(60_000)

    def _build_ui(self):
        central = QWidget()
        self.setCentralWidget(central)
        root = QVBoxLayout(central)
        root.setContentsMargins(0, 0, 0, 0)
        root.setSpacing(0)

        # ── Header ──────────────────────────────────────────────────────────
        header = QWidget()
        header.setObjectName('header')
        header.setFixedHeight(64)
        header.setStyleSheet(f'background:{CARD};border-bottom:1px solid rgba(255,255,255,0.06);')
        h_layout = QHBoxLayout(header)
        h_layout.setContentsMargins(20, 0, 20, 0)
        h_layout.setSpacing(16)

        title = QLabel('Disk Monitor')
        title.setStyleSheet(f'color:{TEXT};font-size:17px;font-weight:700;')
        h_layout.addWidget(title)

        h_layout.addSpacing(24)

        self._bar_home = UsageBar('/home')
        self._bar_root = UsageBar('/')
        h_layout.addWidget(self._bar_home)
        h_layout.addWidget(self._bar_root)

        h_layout.addStretch()

        self._refresh_btn = QPushButton('↻ Refresh')
        self._refresh_btn.setFixedHeight(32)
        self._refresh_btn.clicked.connect(self._refresh_all)
        h_layout.addWidget(self._refresh_btn)

        self._cleanup_btn = QPushButton('⚡ Run Cleanup')
        self._cleanup_btn.setFixedHeight(32)
        self._cleanup_btn.setObjectName('cleanupBtn')
        self._cleanup_btn.clicked.connect(self._trigger_cleanup)
        h_layout.addWidget(self._cleanup_btn)

        root.addWidget(header)

        # ── Tabs ────────────────────────────────────────────────────────────
        self._tabs = QTabWidget()
        self._tabs.setDocumentMode(True)
        root.addWidget(self._tabs)

        self._tab_dash     = DashboardTab()
        self._tab_hist     = HistoryTab()
        self._tab_anal     = AnalyticsTab()
        self._tab_cleanup  = CleanupTab()
        self._tab_settings = SettingsTab()

        self._tabs.addTab(self._tab_dash,     'Dashboard')
        self._tabs.addTab(self._tab_hist,     'History')
        self._tabs.addTab(self._tab_anal,     'Analytics')
        self._tabs.addTab(self._tab_cleanup,  'Cleanup')
        self._tabs.addTab(self._tab_settings, 'Settings')

        self._tab_cleanup.cleanup_done.connect(self._refresh_all)

