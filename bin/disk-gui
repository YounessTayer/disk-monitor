    def _refresh_all(self):
        self._bar_home.refresh()
        self._bar_root.refresh()
        self._tab_dash.refresh()
        self._tab_hist.refresh()
        self._tab_anal.refresh()
        self._tab_cleanup.refresh()

    def _trigger_cleanup(self):
        self._tabs.setCurrentWidget(self._tab_cleanup)
        self._tab_cleanup._run_cleanup()


# ─── Entry point ─────────────────────────────────────────────────────────────
if __name__ == '__main__':
    app = QApplication(sys.argv)
    app.setApplicationName('disk-gui')
    app.setOrganizationName('disk-monitor')

    window = MainWindow()
    window.show()
    sys.exit(app.exec_())
