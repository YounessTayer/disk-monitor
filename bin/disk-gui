# ─── Palette ──────────────────────────────────────────────────────────────────
BG    = '#1e1e1e'
CARD  = '#292929'
CARD2 = '#242424'
INSET = '#212121'
BLUE  = '#3b82f6'
GREEN = '#22c55e'
AMBER = '#f59e0b'
RED   = '#ef4444'
TEAL  = '#14b8a6'
GRAY  = '#8a8a8a'
TEXT  = '#f0f0f0'
SUB   = '#b0b0b0'
DIM   = '#707070'

CHART_COLORS = [TEAL, BLUE, GREEN, AMBER, RED, '#f472b6', '#a78bfa', '#34d399', '#60a5fa']

# ─── Paths ────────────────────────────────────────────────────────────────────
DB_PATH     = Path.home() / '.local/share/disk-monitor/stats.db'
CLEANER     = str(Path.home() / '.local/bin/disk-cleaner')
CONFIG_PATH = Path.home() / '.config/disk-monitor/config.sh'


# ─── Helpers ──────────────────────────────────────────────────────────────────
def fmt_size(kb):
    """Format KB value to human-readable string."""
    if kb is None:
        return '—'
    kb = float(kb)
    if kb >= 1_048_576:
        return f'{kb / 1_048_576:.1f} GB'
    if kb >= 1024:
        return f'{kb / 1024:.0f} MB'
    return f'{kb:.0f} KB'

def trigger_color(trigger):
    t = str(trigger or '').lower()
    if 'critical'  in t: return RED
    if 'threshold' in t: return AMBER
    if 'scheduled' in t or 'cron' in t: return TEAL
    if 'manual'    in t: return BLUE
    return GRAY


# ─── Database ─────────────────────────────────────────────────────────────────
def get_conn():
    if not DB_PATH.exists():
        return None
    try:
        conn = sqlite3.connect(str(DB_PATH))
        conn.row_factory = sqlite3.Row
        return conn
    except Exception:
        return None

def db_fetch(sql, params=()):
    conn = get_conn()
    if conn is None:
        return []
    try:
        rows = conn.execute(sql, params).fetchall()
        conn.close()
        return rows
    except Exception:
        try: conn.close()
        except Exception: pass
        return []

def db_one(sql, params=()):
    rows = db_fetch(sql, params)
    return rows[0] if rows else None


# ─── StatCard ─────────────────────────────────────────────────────────────────
class StatCard(QFrame):
    def __init__(self, label, value='—', sub='', color=TEAL, parent=None):
        super().__init__(parent)
        self._color = color
        self.setObjectName('statCard')
        self.setStyleSheet(f'''
            #statCard {{
                background: {CARD};
                border: 1px solid rgba(255,255,255,0.07);
                border-radius: 10px;
            }}
        ''')
        self.setSizePolicy(QSizePolicy.Expanding, QSizePolicy.Fixed)
        self.setMinimumHeight(104)

        layout = QVBoxLayout(self)
        layout.setContentsMargins(18, 14, 16, 14)
        layout.setSpacing(5)

        # Label row
        top = QHBoxLayout()
        top.setSpacing(6)
        lbl = QLabel(label.upper())
        lbl.setStyleSheet(f'color:{DIM}; font-size:10px; font-weight:700; letter-spacing:0.08em;')
        dot = QLabel('●')
        dot.setStyleSheet(f'color:{color}; font-size:9px;')
        top.addWidget(lbl)
        top.addStretch()
        top.addWidget(dot)
        layout.addLayout(top)

        # Value
        self._val_lbl = QLabel(str(value))
        self._val_lbl.setStyleSheet(f'color:{color}; font-size:24px; font-weight:700;')
        layout.addWidget(self._val_lbl)

        # Sub-label
        self._sub_lbl = QLabel(sub)
        self._sub_lbl.setStyleSheet(f'color:{SUB}; font-size:11px;')
        self._sub_lbl.setVisible(bool(sub))
        layout.addWidget(self._sub_lbl)

    def set_value(self, value, sub=None):
        self._val_lbl.setText(str(value))
        if sub is not None:
            self._sub_lbl.setText(sub)
            self._sub_lbl.setVisible(bool(sub))


# ─── UsageBar ─────────────────────────────────────────────────────────────────
class UsageBar(QWidget):
    def __init__(self, partition, parent=None):
        super().__init__(parent)
        self._partition = partition
        self.setMinimumWidth(240)

        layout = QHBoxLayout(self)
        layout.setContentsMargins(0, 0, 0, 0)
        layout.setSpacing(10)

        lbl = QLabel(partition)
        lbl.setFixedWidth(44)
        lbl.setStyleSheet(f'color:{SUB}; font-family:monospace; font-size:11px; font-weight:600;')
        layout.addWidget(lbl)

        self._bar = QProgressBar()
        self._bar.setTextVisible(False)
        self._bar.setFixedHeight(8)
        self._bar.setRange(0, 100)
        layout.addWidget(self._bar, 1)

        self._pct_lbl = QLabel('—%')
        self._pct_lbl.setFixedWidth(34)
        self._pct_lbl.setStyleSheet(f'color:{TEXT}; font-size:11px; font-weight:700;')
        layout.addWidget(self._pct_lbl)

        self._text = QLabel('— / —')
        self._text.setStyleSheet(f'color:{DIM}; font-size:10px; font-family:monospace;')
        self._text.setFixedWidth(100)
        layout.addWidget(self._text)

        self.refresh()

    def refresh(self):
        try:
            u = shutil.disk_usage(self._partition)
            pct = int(u.used / u.total * 100)
            color = GREEN if pct < 70 else BLUE if pct < 85 else AMBER if pct < 92 else RED
            self._bar.setValue(pct)
            self._bar.setStyleSheet(f'''
                QProgressBar {{ background:{INSET}; border:none; border-radius:4px; }}
                QProgressBar::chunk {{ background:{color}; border-radius:4px; }}
            ''')
            self._pct_lbl.setText(f'{pct}%')
            self._pct_lbl.setStyleSheet(f'color:{color}; font-size:11px; font-weight:700;')
            self._text.setText(f'{u.used/1024**3:.1f}G / {u.total/1024**3:.1f}G')
        except Exception:
            self._bar.setValue(0)
            self._pct_lbl.setText('—%')
            self._text.setText('N/A')


# ─── Chart ────────────────────────────────────────────────────────────────────
class Chart(FigureCanvas):
    def __init__(self, figsize=(6, 3), parent=None):
        self._fig = Figure(figsize=figsize, facecolor=CARD)
        super().__init__(self._fig)
        self.setParent(parent)
        self.setSizePolicy(QSizePolicy.Expanding, QSizePolicy.Expanding)
        self._ax = self._fig.add_subplot(111)
        self._style_ax(self._ax)

    def _style_ax(self, ax):
        ax.set_facecolor(INSET)
        ax.tick_params(colors=DIM, labelsize=9, length=3)
        for spine in ax.spines.values():
            spine.set_edgecolor('#333333')
        ax.grid(color='#333333', linestyle='--', linewidth=0.8, alpha=0.8)

    def clear(self):
        self._fig.clear()
        self._ax = self._fig.add_subplot(111)
        self._style_ax(self._ax)

    def no_data(self, msg='No data — run disk-cleaner first'):
        self.clear()
        self._ax.text(0.5, 0.5, msg,
            transform=self._ax.transAxes,
            ha='center', va='center',
            color=DIM, fontsize=11, style='italic')
        self._ax.set_xticks([])
        self._ax.set_yticks([])
        self.draw()


# ─── Tab 1: Dashboard ─────────────────────────────────────────────────────────
class DashboardTab(QWidget):
    def __init__(self, parent=None):
        super().__init__(parent)
        root = QVBoxLayout(self)
        root.setContentsMargins(20, 20, 20, 20)
        root.setSpacing(16)

        # Stat cards
        cards_row = QHBoxLayout()
        cards_row.setSpacing(12)
        self._card_freed = StatCard('Total Freed',  '—', 'all time', TEAL)
        self._card_runs  = StatCard('Cleanups Run', '0', '',         BLUE)
        self._card_last  = StatCard('Last Cleanup', '—', '',         GREEN)
        self._card_avg   = StatCard('Avg per Run',  '—', '',         AMBER)
        for c in (self._card_freed, self._card_runs, self._card_last, self._card_avg):
            cards_row.addWidget(c)
        root.addLayout(cards_row)

        # Charts row
        charts_row = QHBoxLayout()
        charts_row.setSpacing(12)

        # Donut frame
        donut_frame = self._card_frame('Freed by Cache Type  —  all time')
        self._donut = Chart(figsize=(5, 2.8))
        donut_frame.layout().addWidget(self._donut)
        # Qt legend — 2-column grid of colored dot + text items
        self._legend_widget = QWidget()
        self._legend_widget.setStyleSheet('background:transparent;')
        from PyQt5.QtWidgets import QGridLayout
        self._legend_grid = QGridLayout(self._legend_widget)
        self._legend_grid.setContentsMargins(4, 0, 4, 4)
        self._legend_grid.setHorizontalSpacing(16)
        self._legend_grid.setVerticalSpacing(4)
        donut_frame.layout().addWidget(self._legend_widget)
        charts_row.addWidget(donut_frame, 3)

        # Recent table frame
        recent_frame = self._card_frame('Recent Cleanups')
        self._recent_tbl = self._make_table(['Time', 'Trigger', 'Freed'])
        recent_frame.layout().addWidget(self._recent_tbl)
        charts_row.addWidget(recent_frame, 2)

        root.addLayout(charts_row)

    def _card_frame(self, title):
        frame = QFrame()
        frame.setStyleSheet(f'''
            QFrame {{
                background:{CARD};
                border:1px solid rgba(255,255,255,0.07);
                border-radius:10px;
            }}
        ''')
        lay = QVBoxLayout(frame)
        lay.setContentsMargins(16, 14, 16, 14)
        lay.setSpacing(10)
        lbl = QLabel(title)
        lbl.setStyleSheet(f'color:{SUB}; font-size:11px; font-weight:700; letter-spacing:0.04em;')
        lay.addWidget(lbl)
        sep = QFrame()
        sep.setFrameShape(QFrame.HLine)
        sep.setStyleSheet('background:rgba(255,255,255,0.06); max-height:1px;')
        lay.addWidget(sep)
        return frame

    def _make_table(self, headers):
        tbl = QTableWidget(0, len(headers))
        tbl.setHorizontalHeaderLabels(headers)
        tbl.horizontalHeader().setSectionResizeMode(QHeaderView.Stretch)
        tbl.setEditTriggers(QTableWidget.NoEditTriggers)
        tbl.setSelectionMode(QTableWidget.NoSelection)
        tbl.verticalHeader().setVisible(False)
        tbl.setShowGrid(False)
        return tbl

    def refresh(self):
        row = db_one('SELECT SUM(total_freed) as tot, COUNT(*) as cnt FROM cleanups')
        tot_kb = float(row['tot'] or 0) if row else 0
        cnt    = int(row['cnt'] or 0)   if row else 0
        avg_kb = tot_kb / cnt if cnt else 0

        self._card_freed.set_value(fmt_size(tot_kb))
        self._card_runs.set_value(str(cnt))
        self._card_avg.set_value(fmt_size(avg_kb))

        last = db_one('SELECT ts FROM cleanups ORDER BY ts DESC LIMIT 1')
        if last:
            try:
                dt = datetime.fromisoformat(last['ts'])
                self._card_last.set_value(dt.strftime('%b %d'), dt.strftime('%H:%M'))
            except Exception:
                self._card_last.set_value(str(last['ts'])[:10])
        else:
            self._card_last.set_value('Never')

        # Donut
        rows = db_fetch(
            'SELECT name, SUM(freed_kb) as tot FROM actions '
            'WHERE status="ok" AND freed_kb>0 GROUP BY name ORDER BY tot DESC'
        )
        self._donut.clear()
        ax = self._donut._ax

        # Clear Qt legend grid
        while self._legend_grid.count():
            item = self._legend_grid.takeAt(0)
            if item.widget():
                item.widget().deleteLater()

        if rows:
            names  = [r['name'].replace('_', ' ').title() for r in rows]
            values = [float(r['tot']) for r in rows]
            total  = sum(values)
            colors = CHART_COLORS[:len(names)]

            # Draw donut — no legend inside matplotlib
            ax.pie(
                values, labels=None, colors=colors, startangle=90,
                wedgeprops=dict(width=0.52, edgecolor=INSET, linewidth=2),
            )
            self._donut._fig.subplots_adjust(left=0.02, right=0.98, top=0.97, bottom=0.03)
            self._donut.draw()

            # Build native Qt legend — 2 columns
            for i, (name, val, color) in enumerate(zip(names, values, colors)):
                dot = QLabel('●')
                dot.setStyleSheet(f'color:{color}; font-size:10px; background:transparent;')
                dot.setFixedWidth(14)
                text = QLabel(f'<span style="color:{color};">{name}</span>  <span style="color:{SUB};">{fmt_size(val)}</span>  <span style="color:{DIM};">({val/total*100:.0f}%)</span>')
                text.setStyleSheet(f'font-size:10px; background:transparent;')
                text.setTextFormat(Qt.RichText)
                row, col_base = divmod(i, 2)
                self._legend_grid.addWidget(dot,  row, col_base * 2)
                self._legend_grid.addWidget(text, row, col_base * 2 + 1)
        else:
            self._donut.no_data()

        # Recent table
        recent = db_fetch(
            'SELECT ts, trigger, total_freed FROM cleanups ORDER BY ts DESC LIMIT 8'
        )
        self._recent_tbl.setRowCount(len(recent))
        for i, r in enumerate(recent):
            try:
                dt = datetime.fromisoformat(r['ts'])
                ts_str = dt.strftime('%b %d  %H:%M')
            except Exception:
                ts_str = str(r['ts'])[:16]
            trig = str(r['trigger'] or '')
            freed = fmt_size(float(r['total_freed'] or 0))

            items = [
                (ts_str,  TEXT),
                (trig,    trigger_color(trig)),
                (freed,   GREEN if float(r['total_freed'] or 0) > 0 else DIM),
            ]
            for col, (text, color) in enumerate(items):
                item = QTableWidgetItem(text)
                item.setForeground(QColor(color))
                self._recent_tbl.setItem(i, col, item)
        self._recent_tbl.resizeRowsToContents()


# ─── Tab 2: History ───────────────────────────────────────────────────────────
class HistoryTab(QWidget):
    def __init__(self, parent=None):
        super().__init__(parent)
        root = QVBoxLayout(self)
        root.setContentsMargins(20, 20, 20, 20)

        splitter = QSplitter(Qt.Vertical)
        splitter.setChildrenCollapsible(False)

        # Top — all cleanups
        top = QWidget()
        tl = QVBoxLayout(top)
        tl.setContentsMargins(0, 0, 0, 0)
        tl.setSpacing(8)
        ttl = QLabel('All Cleanups')
        ttl.setStyleSheet(f'color:{SUB}; font-size:11px; font-weight:700; letter-spacing:0.04em;')
        tl.addWidget(ttl)
        self._cleanups_tbl = QTableWidget(0, 4)
        self._cleanups_tbl.setHorizontalHeaderLabels(['Timestamp', 'Trigger', 'Freed', '/home Saved'])
        hdr = self._cleanups_tbl.horizontalHeader()
        hdr.setSectionResizeMode(0, QHeaderView.ResizeToContents)
        hdr.setSectionResizeMode(1, QHeaderView.Stretch)
        hdr.setSectionResizeMode(2, QHeaderView.ResizeToContents)
        hdr.setSectionResizeMode(3, QHeaderView.ResizeToContents)
        self._cleanups_tbl.setEditTriggers(QTableWidget.NoEditTriggers)
        self._cleanups_tbl.setSelectionMode(QTableWidget.SingleSelection)
        self._cleanups_tbl.setSelectionBehavior(QTableWidget.SelectRows)
        self._cleanups_tbl.verticalHeader().setVisible(False)
        self._cleanups_tbl.setShowGrid(False)
        self._cleanups_tbl.selectionModel().selectionChanged.connect(self._on_select)
        tl.addWidget(self._cleanups_tbl)
        splitter.addWidget(top)

        # Bottom — per-cleaner breakdown
        bot = QWidget()
        bl = QVBoxLayout(bot)
        bl.setContentsMargins(0, 8, 0, 0)
        bl.setSpacing(8)
        ttl2 = QLabel('Cleaner Breakdown')
        ttl2.setStyleSheet(f'color:{SUB}; font-size:11px; font-weight:700; letter-spacing:0.04em;')
        bl.addWidget(ttl2)
        self._placeholder = QLabel('Select a cleanup above to see details')
        self._placeholder.setAlignment(Qt.AlignCenter)
        self._placeholder.setStyleSheet(f'color:{DIM}; font-size:12px; font-style:italic;')
        bl.addWidget(self._placeholder)
        self._detail_tbl = QTableWidget(0, 3)
        self._detail_tbl.setHorizontalHeaderLabels(['Cleaner', 'Freed', 'Status'])
        self._detail_tbl.horizontalHeader().setSectionResizeMode(0, QHeaderView.Stretch)
        self._detail_tbl.horizontalHeader().setSectionResizeMode(1, QHeaderView.ResizeToContents)
        self._detail_tbl.horizontalHeader().setSectionResizeMode(2, QHeaderView.ResizeToContents)
        self._detail_tbl.setEditTriggers(QTableWidget.NoEditTriggers)
        self._detail_tbl.setSelectionMode(QTableWidget.NoSelection)
        self._detail_tbl.verticalHeader().setVisible(False)
        self._detail_tbl.setShowGrid(False)
        self._detail_tbl.hide()
        bl.addWidget(self._detail_tbl)
        splitter.addWidget(bot)

        splitter.setSizes([340, 220])
        root.addWidget(splitter)
        self._cleanup_ids = []

    def refresh(self):
        rows = db_fetch(
            'SELECT id, ts, trigger, total_freed, home_before, home_after '
            'FROM cleanups ORDER BY ts DESC'
        )
        self._cleanup_ids = [r['id'] for r in rows]
        self._cleanups_tbl.setRowCount(len(rows))
        for i, r in enumerate(rows):
            try:
                dt = datetime.fromisoformat(r['ts'])
                ts_str = dt.strftime('%Y-%m-%d   %H:%M')
            except Exception:
                ts_str = str(r['ts'])[:16]
            freed_kb   = float(r['total_freed'] or 0)
            home_b     = float(r['home_before'] or 0)
            home_a     = float(r['home_after']  or 0)
            delta_kb   = home_b - home_a
            delta_str  = f'↓ {fmt_size(delta_kb)}' if delta_kb > 0 else '—'
            trig       = str(r['trigger'] or '')
            col3_color = GREEN if delta_kb > 0 else DIM

            data = [
                (ts_str,            TEXT),
                (trig,              trigger_color(trig)),
                (fmt_size(freed_kb), GREEN if freed_kb > 0 else DIM),
                (delta_str,          col3_color),
            ]
            for col, (text, color) in enumerate(data):
                item = QTableWidgetItem(text)
                item.setForeground(QColor(color))
                self._cleanups_tbl.setItem(i, col, item)
        self._cleanups_tbl.resizeRowsToContents()

    def _on_select(self):
        idx = self._cleanups_tbl.currentRow()
        if idx < 0 or idx >= len(self._cleanup_ids):
            self._detail_tbl.hide()
            self._placeholder.show()
            return
        cid = self._cleanup_ids[idx]
        actions = db_fetch(
            'SELECT name, freed_kb, status FROM actions '
            'WHERE cleanup_id=? ORDER BY freed_kb DESC',
            (cid,)
        )
        self._detail_tbl.setRowCount(len(actions))
        STATUS_COLORS = {'ok': GREEN, 'error': RED, 'skipped': GRAY}
        for i, a in enumerate(actions):
            name   = str(a['name'] or '').replace('_', ' ').title()
            freed  = fmt_size(float(a['freed_kb'] or 0))
            status = str(a['status'] or '')
            data   = [
                (name,   TEXT),
                (freed,  GREEN if float(a['freed_kb'] or 0) > 0 else DIM),
                (status, STATUS_COLORS.get(status, SUB)),
            ]
            for col, (text, color) in enumerate(data):
                item = QTableWidgetItem(text)
                item.setForeground(QColor(color))
                self._detail_tbl.setItem(i, col, item)
        self._detail_tbl.resizeRowsToContents()
        self._placeholder.hide()
        self._detail_tbl.show()


# ─── Tab 3: Analytics ─────────────────────────────────────────────────────────
class AnalyticsTab(QWidget):
    def __init__(self, parent=None):
        super().__init__(parent)
        root = QVBoxLayout(self)
        root.setContentsMargins(20, 20, 20, 20)
        root.setSpacing(14)

        # /home usage trend
        f1 = self._chart_frame('/home Usage %  —  Last 30 Days')
        self._usage_chart = Chart(figsize=(8, 2.8))
        f1.layout().addWidget(self._usage_chart)
        root.addWidget(f1)

        # Freed per run
        f2 = self._chart_frame('Space Freed per Cleanup  —  Last 20 Runs')
        self._freed_chart = Chart(figsize=(8, 2.8))
        f2.layout().addWidget(self._freed_chart)

        # Legend row
        legend = QHBoxLayout()
        legend.setSpacing(16)
        for label, color in [('Manual', BLUE), ('Threshold', AMBER), ('Critical', RED), ('Scheduled', TEAL), ('Other', GRAY)]:
            dot = QLabel(f'● {label}')
            dot.setStyleSheet(f'color:{color}; font-size:10px;')
            legend.addWidget(dot)
        legend.addStretch()
        f2.layout().addLayout(legend)

        root.addWidget(f2)

    def _chart_frame(self, title):
        frame = QFrame()
        frame.setStyleSheet(f'''
            QFrame {{
                background:{CARD};
                border:1px solid rgba(255,255,255,0.07);
                border-radius:10px;
            }}
        ''')
        lay = QVBoxLayout(frame)
        lay.setContentsMargins(16, 14, 16, 10)
        lay.setSpacing(8)
        lbl = QLabel(title)
        lbl.setStyleSheet(f'color:{SUB}; font-size:11px; font-weight:700; letter-spacing:0.04em;')
        lay.addWidget(lbl)
        sep = QFrame()
        sep.setFrameShape(QFrame.HLine)
        sep.setStyleSheet('background:rgba(255,255,255,0.06); max-height:1px;')
        lay.addWidget(sep)
        return frame

    def refresh(self):
        self._draw_usage()
        self._draw_freed()

    def _draw_usage(self):
        cutoff = (datetime.now() - timedelta(days=30)).isoformat()
        rows = db_fetch(
            'SELECT date(ts) as day, AVG(used_kb*100.0/total_kb) as pct '
            'FROM snapshots WHERE partition="/home" AND ts>=? '
            'GROUP BY date(ts) ORDER BY day',
            (cutoff,)
        )
        self._usage_chart.clear()
        ax = self._usage_chart._ax
        if rows:
            days = [r['day'] for r in rows]
            pcts = [float(r['pct'] or 0) for r in rows]
            xs   = list(range(len(days)))
            ax.plot(xs, pcts, color=BLUE, linewidth=2, marker='o', markersize=5,
                    markerfacecolor=BLUE, markeredgecolor=INSET, markeredgewidth=1.5)
            ax.fill_between(xs, pcts, alpha=0.12, color=BLUE)
            # Threshold lines
            ax.axhline(y=85, color=AMBER, linewidth=0.8, linestyle='--', alpha=0.6, label='Clean 85%')
            ax.axhline(y=92, color=RED,   linewidth=0.8, linestyle='--', alpha=0.6, label='Critical 92%')
            step = max(1, len(days) // 7)
            ax.set_xticks(xs[::step])
            ax.set_xticklabels([days[i][5:] for i in xs[::step]], color=DIM, fontsize=8, rotation=20)
            ax.set_ylim(max(0, min(pcts) - 5), 101)
            ax.set_ylabel('%', color=DIM, fontsize=9)
            ax.yaxis.label.set_color(DIM)
            ax.legend(fontsize=7.5, framealpha=0, labelcolor=DIM, loc='lower right')
            self._usage_chart._fig.subplots_adjust(left=0.06, right=0.98, top=0.95, bottom=0.22)
            self._usage_chart.draw()
        else:
            self._usage_chart.no_data('No /home snapshots yet — check back after the monitor runs')

    def _draw_freed(self):
        rows = db_fetch(
            'SELECT ts, trigger, total_freed FROM cleanups ORDER BY ts DESC LIMIT 20'
        )
        self._freed_chart.clear()
        ax = self._freed_chart._ax
        if rows:
            rows = list(reversed(rows))
            values = [(float(r['total_freed'] or 0) / 1024) for r in rows]
            colors = [trigger_color(r['trigger']) for r in rows]
            xs     = list(range(len(rows)))
            bars   = ax.bar(xs, values, color=colors, width=0.65,
                            edgecolor=INSET, linewidth=0.5)
            # Value labels on bars
            for bar, val in zip(bars, values):
                if val > 0:
                    ax.text(bar.get_x() + bar.get_width() / 2, bar.get_height() + max(values)*0.01,
                            f'{val:.0f}', ha='center', va='bottom', fontsize=7, color=DIM)
            labels = []
            for r in rows:
                try:
                    dt = datetime.fromisoformat(r['ts'])
                    labels.append(dt.strftime('%m/%d'))
                except Exception:
                    labels.append(str(r['ts'])[:5])
            step = max(1, len(rows) // 8)
            ax.set_xticks(xs[::step])
            ax.set_xticklabels([labels[i] for i in xs[::step]], color=DIM, fontsize=8, rotation=20)
            ax.set_ylabel('MB', color=DIM, fontsize=9)
            ax.yaxis.label.set_color(DIM)
            self._freed_chart._fig.subplots_adjust(left=0.07, right=0.98, top=0.88, bottom=0.22)
            self._freed_chart.draw()
        else:
            self._freed_chart.no_data('No cleanups yet')


# ─── Tab 4: Cleanup ───────────────────────────────────────────────────────────
class CleanupTab(QWidget):
    cleanup_done = pyqtSignal()

    def __init__(self, parent=None):
        super().__init__(parent)
        root = QVBoxLayout(self)
        root.setContentsMargins(20, 20, 20, 20)
        root.setSpacing(14)

        # Disk status bar
        status_frame = QFrame()
        status_frame.setStyleSheet(f'''
            QFrame {{
                background:{CARD};
                border:1px solid rgba(255,255,255,0.07);
                border-radius:10px;
            }}
        ''')
        sf_lay = QHBoxLayout(status_frame)
        sf_lay.setContentsMargins(18, 14, 18, 14)
        sf_lay.setSpacing(32)
        self._bar_home = UsageBar('/home')
        self._bar_root = UsageBar('/')
        sf_lay.addWidget(self._bar_home, 1)
        sf_lay.addWidget(self._bar_root, 1)
        root.addWidget(status_frame)

        # Run button — solid, prominent
        self._run_btn = QPushButton('  Run Cleanup Now')
        self._run_btn.setObjectName('primaryBtn')
        self._run_btn.setFixedHeight(48)
        self._run_btn.setFont(QFont('sans-serif', 13, QFont.Bold))
        self._run_btn.clicked.connect(self._run_cleanup)
        root.addWidget(self._run_btn)

        # Output frame
        out_frame = QFrame()
        out_frame.setStyleSheet(f'''
            QFrame {{
                background:{CARD};
                border:1px solid rgba(255,255,255,0.07);
                border-radius:10px;
            }}
        ''')
        of_lay = QVBoxLayout(out_frame)
        of_lay.setContentsMargins(14, 12, 14, 12)
        of_lay.setSpacing(8)
        out_hdr = QHBoxLayout()
        out_lbl = QLabel('Output Log')
        out_lbl.setStyleSheet(f'color:{SUB}; font-size:11px; font-weight:700; letter-spacing:0.04em;')
        out_hdr.addWidget(out_lbl)
        out_hdr.addStretch()
        self._status_lbl = QLabel('Idle')
        self._status_lbl.setStyleSheet(f'color:{DIM}; font-size:11px;')
        out_hdr.addWidget(self._status_lbl)
        of_lay.addLayout(out_hdr)
        sep = QFrame()
        sep.setFrameShape(QFrame.HLine)
        sep.setStyleSheet('background:rgba(255,255,255,0.06); max-height:1px;')
        of_lay.addWidget(sep)
        self._output = QTextEdit()
        self._output.setReadOnly(True)
        self._output.setFont(QFont('Ubuntu Mono, Consolas, monospace', 10))
        self._output.setSizePolicy(QSizePolicy.Expanding, QSizePolicy.Expanding)
        of_lay.addWidget(self._output)
        root.addWidget(out_frame)

        self._process = None

    def refresh(self):
        self._bar_home.refresh()
        self._bar_root.refresh()

    def _run_cleanup(self):
        if not os.path.exists(CLEANER):
            self._output.append(f'<span style="color:{RED};">disk-cleaner not found at {CLEANER}</span>')
            return
        self._run_btn.setEnabled(False)
        self._output.clear()
        self._status_lbl.setText('Running…')
        self._status_lbl.setStyleSheet(f'color:{AMBER}; font-size:11px; font-weight:600;')

        self._process = QProcess(self)
        self._process.setProcessChannelMode(QProcess.MergedChannels)
        self._process.readyReadStandardOutput.connect(self._on_output)
        self._process.finished.connect(self._on_done)
        self._process.start(CLEANER, [])

    def _on_output(self):
        if self._process:
            data = bytes(self._process.readAllStandardOutput()).decode('utf-8', errors='replace')
            self._output.moveCursor(self._output.textCursor().End)
            self._output.insertPlainText(data)

    def _on_done(self, exit_code, _):
        self._run_btn.setEnabled(True)
        if exit_code == 0:
            self._status_lbl.setText('Done')
            self._status_lbl.setStyleSheet(f'color:{GREEN}; font-size:11px; font-weight:600;')
        else:
            self._status_lbl.setText(f'Exited with code {exit_code}')
            self._status_lbl.setStyleSheet(f'color:{RED}; font-size:11px; font-weight:600;')
        self.refresh()
        self.cleanup_done.emit()


# ─── Tab 5: Settings ─────────────────────────────────────────────────────────
class SettingsTab(QWidget):
    def __init__(self, parent=None):
        super().__init__(parent)
        root = QVBoxLayout(self)
        root.setContentsMargins(20, 20, 20, 20)
        root.setSpacing(16)

        # Thresholds group
        grp1 = self._group('Disk Thresholds')
        self._warn     = self._spin_row(grp1, 'Warn at',     0, 100, '%')
        self._clean    = self._spin_row(grp1, 'Auto-clean at',  0, 100, '%')
        self._critical = self._spin_row(grp1, 'Critical alert at', 0, 100, '%')
        root.addWidget(grp1)

        # Intervals group
        grp2 = self._group('Timing')
        self._check    = self._spin_row(grp2, 'Check interval',    1, 1440, 'min')
        self._snapshot = self._spin_row(grp2, 'Snapshot interval', 1, 1440, 'min')
        self._cooldown = self._spin_row(grp2, 'Cooldown between auto-cleans', 0, 720, 'hours')
        root.addWidget(grp2)

        # Buttons
        btn_row = QHBoxLayout()
        btn_row.setSpacing(10)
        save_btn = QPushButton('Save Settings')
        save_btn.setObjectName('primaryBtn')
        save_btn.setFixedHeight(40)
        save_btn.clicked.connect(self._save)
        restart_btn = QPushButton('Restart Monitor Service')
        restart_btn.setFixedHeight(40)
        restart_btn.clicked.connect(self._restart_service)
        btn_row.addWidget(save_btn)
        btn_row.addWidget(restart_btn)
        btn_row.addStretch()
        root.addLayout(btn_row)

        self._msg = QLabel('')
        self._msg.setStyleSheet(f'color:{GREEN}; font-size:12px;')
        root.addWidget(self._msg)
        root.addStretch()

        self._load_config()

    def _group(self, title):
        grp = QFrame()
        grp.setStyleSheet(f'''
            QFrame {{
                background:{CARD};
                border:1px solid rgba(255,255,255,0.07);
                border-radius:10px;
            }}
        ''')
        lay = QVBoxLayout(grp)
        lay.setContentsMargins(18, 14, 18, 16)
        lay.setSpacing(12)
        lbl = QLabel(title.upper())
        lbl.setStyleSheet(f'color:{DIM}; font-size:10px; font-weight:700; letter-spacing:0.08em;')
        lay.addWidget(lbl)
        sep = QFrame()
        sep.setFrameShape(QFrame.HLine)
        sep.setStyleSheet('background:rgba(255,255,255,0.06); max-height:1px;')
        lay.addWidget(sep)
        return grp

    def _spin_row(self, parent_frame, label, lo, hi, suffix):
        row = QHBoxLayout()
        lbl = QLabel(label + ':')
        lbl.setStyleSheet(f'color:{TEXT}; font-size:12px;')
        lbl.setFixedWidth(240)
        spin = QSpinBox()
        spin.setRange(lo, hi)
        spin.setSuffix(f'  {suffix}')
        spin.setFixedWidth(120)
        row.addWidget(lbl)
        row.addWidget(spin)
        row.addStretch()
        parent_frame.layout().addLayout(row)
        return spin

    def _load_config(self):
        if not CONFIG_PATH.exists():
            return
        try:
            text = CONFIG_PATH.read_text()
            def gv(key, default=0):
                m = re.search(rf'^{key}\s*=\s*(\d+)', text, re.MULTILINE)
                return int(m.group(1)) if m else default
            self._warn.setValue(gv('WARN_THRESHOLD', 80))
            self._clean.setValue(gv('CLEAN_THRESHOLD', 85))
            self._critical.setValue(gv('CRITICAL_THRESHOLD', 92))
            self._cooldown.setValue(gv('COOLDOWN', 14400) // 3600)
            self._check.setValue(gv('CHECK_INTERVAL', 300) // 60)
            self._snapshot.setValue(gv('SNAPSHOT_INTERVAL', 1800) // 60)
        except Exception as e:
            self._msg.setStyleSheet(f'color:{RED}; font-size:12px;')
            self._msg.setText(f'Error loading config: {e}')

    def _save(self):
        if not CONFIG_PATH.exists():
            self._msg.setStyleSheet(f'color:{RED}; font-size:12px;')
            self._msg.setText('Config file not found.')
            return
        try:
            text = CONFIG_PATH.read_text()
            def rv(key, val):
                return re.sub(rf'^({key}\s*=\s*)\d+', lambda m: m.group(1) + str(val), text, flags=re.MULTILINE)
            text = rv('WARN_THRESHOLD',     self._warn.value())
            text = rv('CLEAN_THRESHOLD',    self._clean.value())
            text = rv('CRITICAL_THRESHOLD', self._critical.value())
            text = rv('COOLDOWN',           self._cooldown.value() * 3600)
            text = rv('CHECK_INTERVAL',     self._check.value() * 60)
            text = rv('SNAPSHOT_INTERVAL',  self._snapshot.value() * 60)
            CONFIG_PATH.write_text(text)
            self._msg.setStyleSheet(f'color:{GREEN}; font-size:12px;')
            self._msg.setText('Settings saved successfully.')
        except Exception as e:
            self._msg.setStyleSheet(f'color:{RED}; font-size:12px;')
            self._msg.setText(f'Error: {e}')

    def _restart_service(self):
        proc = QProcess(self)
        proc.start('systemctl', ['--user', 'restart', 'disk-monitor.service'])
        proc.waitForFinished(5000)
        if proc.exitCode() == 0:
            self._msg.setStyleSheet(f'color:{GREEN}; font-size:12px;')
            self._msg.setText('Monitor service restarted.')
        else:
            self._msg.setStyleSheet(f'color:{RED}; font-size:12px;')
            self._msg.setText(f'Restart failed (exit {proc.exitCode()}).')


